<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.wwc.x.infrastructure.dao.IFormSubmissionDao">

    <resultMap id="BaseResultMap" type="cn.wwc.x.infrastructure.dao.po.FormSubmissionPO">
        <id column="id" property="id"/>
        <result column="form_id" property="formId"/>
        <result column="form_key" property="formKey"/>
        <result column="submit_data" property="submitData"/>
        <result column="submitter_name" property="submitterName"/>
        <result column="submitter_phone" property="submitterPhone"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <insert id="insert" parameterType="cn.wwc.x.infrastructure.dao.po.FormSubmissionPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO form_submission (form_id, form_key, submit_data, submitter_name, submitter_phone, ip_address)
        VALUES (#{formId}, #{formKey}, #{submitData}, #{submitterName}, #{submitterPhone}, #{ipAddress})
    </insert>

    <select id="selectByFormId" resultMap="BaseResultMap">
        SELECT * FROM form_submission WHERE form_id = #{formId} ORDER BY created_at DESC
    </select>

    <select id="countByFormId" resultType="long">
        SELECT COUNT(*) FROM form_submission WHERE form_id = #{formId}
    </select>

</mapper>
